. "$HOME/.cargo/env"
eval "$(starship init zsh)"
{{- with .machine.postgresqlBinDir }}
export PATH={{ . | quote }}:"$PATH"
{{- else }}
if command -v brew >/dev/null 2>&1; then
    pg_prefix="$(brew --prefix postgresql@16 2>/dev/null || true)"
    if [ -n "$pg_prefix" ]; then
        export PATH="$pg_prefix/bin:$PATH"
    fi
fi
{{- end }}
. "$HOME/.local/bin/env"
