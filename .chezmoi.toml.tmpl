{{- $name := promptStringOnce . "name" "Full name for git and cookiecutter" -}}
{{- $email := promptStringOnce . "email" "Email address for git and cookiecutter" -}}
[data.identity]
name = {{ $name | quote }}
email = {{ $email | quote }}

[data.machine]
browser = ""
postgresqlBinDir = ""
gitCredentialHelper = ""
gitCredentialStore = ""
pulseServer = ""

